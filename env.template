# ============================================
# Projects.AI Environment Variables
# ============================================
# Copy: cp env.template .env.local

# ============================================
# SUPABASE (required)
# ============================================
# Project Settings → API in Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Project Settings → API → service_role (server only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: direct Postgres URL for scripts / Drizzle Studio
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ============================================
# GOOGLE GEMINI AI
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ============================================
# TRANSACTIONAL EMAIL (team invites, task notifications)
# ============================================
# Auth signup / reset emails use Resend via Supabase Dashboard → Authentication → SMTP
# (see SUPABASE_SETUP.md). These keys power in-app emails in lib/email/resend.ts.
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Projects.AI

# ============================================
# PLATFORM ADMIN (super admin)
# ============================================
# Comma-separated emails that become platform super admins (no org on signup)
SUPER_ADMIN_EMAILS=you@yourdomain.com

# ============================================
# APPLICATION
# ============================================
# Local: http://localhost:3000
# Production (Vercel): https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# VERCEL DEPLOYMENT (required on Vercel dashboard)
# ============================================
# Copy ALL variables above into Vercel → Project → Settings → Environment Variables:
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY   (anon or publishable key from Supabase → API)
#   SUPABASE_SERVICE_ROLE_KEY       (required for sign-up / profile provisioning)
#   GEMINI_API_KEY
#   NEXT_PUBLIC_APP_URL             (your production URL)
#   SUPER_ADMIN_EMAILS              (optional)
#   RESEND_*                        (optional, for in-app emails)
#
# Performance: In Vercel → Project → Settings → Functions, set the region to match
# your Supabase project region (Supabase Dashboard → Project Settings → General).
# Mismatched regions add 100–300ms per database round trip.
