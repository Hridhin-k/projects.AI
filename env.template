# ============================================
# Projects.AI Environment Variables
# ============================================
# Copy: cp env.template .env.local

# ============================================
# SUPABASE (required)
# ============================================
# Project Settings → API in Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Project Settings → API → service_role (server only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: direct Postgres URL for scripts / Drizzle Studio
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ============================================
# GOOGLE GEMINI AI
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# ============================================
# TRANSACTIONAL EMAIL (team invites in the app)
# ============================================
# Auth signup / reset emails use Resend via Supabase Dashboard → Authentication → SMTP
# (see SUPABASE_SETUP.md). These keys are for in-app invite emails only (Brevo today).
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your_verified_email@yourdomain.com
BREVO_SENDER_NAME=Projects.AI

# Optional: if you migrate invite emails to Resend in code later
# RESEND_API_KEY=re_your_key_here
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# PLATFORM ADMIN (super admin)
# ============================================
# Comma-separated emails that become platform super admins (no org on signup)
SUPER_ADMIN_EMAILS=you@yourdomain.com

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
